@model OstaFeedbackApp.Models.Feedback
@using System.Text.Json
@{
    Layout = null;

    // Serialize model safely (empty object if null) to avoid JS errors
    var jsonData = JsonSerializer.Serialize(Model ?? new OstaFeedbackApp.Models.Feedback());
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>OSTA Exhibition Feedback Form</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        /* ===== GLOBAL & BACKGROUND ===== */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: linear-gradient(180deg, #004a99 0%, #ffffff 60%);
            background-attachment: fixed;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        /* ===== HEADER ===== */
        .header {
            background-color: #003366;
            color: white;
            padding: 20px;
            text-align: center;
        }

            .header img {
                max-height: 80px;
                margin-right: 20px;
                vertical-align: middle;
            }

            .header h2 {
                color: white;
                font-weight: 700;
                font-size: 28px;
                margin: 0;
                display: inline-block;
                vertical-align: middle;
            }

        /* ===== MAIN CONTENT (form container) ===== */
        .main-content {
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Theme info – now using dark blue for better visibility */
        .theme-info p {
            margin: 3px 0;
            font-size: 14px;
            color: #003366; /* Dark blue, matches header */
            font-weight: 500;
        }

            .theme-info p strong {
                color: #003366;
                font-weight: 700;
            }

        /* Form sections */
        .form-section {
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.08);
            margin-bottom: 25px;
        }

            .form-section h4 {
                margin-bottom: 15px;
                font-weight: 600;
                color: #003366;
                display: flex;
                align-items: center;
                gap: 10px;
            }

        .question {
            margin-top: 20px;
        }

        /* Rating buttons */
        .rating input[type="radio"] {
            display: none;
        }

        .rating label {
            display: inline-block;
            width: 40px;
            height: 40px;
            line-height: 40px;
            border-radius: 50%;
            background: #e0e0e0;
            text-align: center;
            margin-right: 8px;
            cursor: pointer;
            font-weight: bold;
            color: #555;
            transition: all 0.3s ease;
        }

        .rating input[type="radio"]:checked + label {
            background: linear-gradient(135deg, #003366, #1E90FF);
            color: #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

        /* Inputs and textareas */
        textarea, input, select {
            width: 100%;
            margin-bottom: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 14px;
            transition: all 0.3s ease;
        }

            textarea:focus, input:focus, select:focus {
                border-color: #1E90FF;
                box-shadow: 0 0 8px rgba(30,144,255,0.2);
                outline: none;
            }

        /* Buttons */
        .btn-primary {
            background: #003366;
            border-color: #003366;
            padding: 10px 25px;
            font-size: 16px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                background: #1E90FF;
                border-color: #1E90FF;
            }

        /* Responsive adjustments */
        @@media (max-width: 768px) {
            .header {
                padding: 15px;
            }

                .header img {
                    max-height: 60px;
                    margin-right: 10px;
                    display: block;
                    margin: 0 auto 10px auto;
                }

                .header h2 {
                    font-size: 22px;
                    display: block;
                }

            .main-content {
                padding: 15px;
            }
        }
    </style>
</head>

<body>

    <!-- Header (full width, dark blue background) -->
    <header class="header">
        <img src="~/images/osta-logo.webp" asp-append-version="true" alt="OSTA Logo" />
        <h2>OSTA Exhibition Feedback Form</h2>
    </header>

    <!-- Main content area (padding & centering) -->
    <div class="main-content">
        <!-- Theme Info -->
        <div class="theme-info mb-4">
            <p><strong>Theme:</strong> Commitment through Action: Digital Transformation and Technological Innovation in Oromia</p>
            <p><strong>Organizer:</strong> Oromia Science and Technology Authority (OSTA)</p>
            <p><strong>Date:</strong> March 31 – April 2, 2026</p>
            <p><strong>Location:</strong> Oromo Cultural Center, Finfinne </p>
        </div>

        <!-- Form -->
        <form asp-action="Create" method="post">

            <!-- Section 1: Ratings -->
            <div class="form-section">
                <h4>🔹 Section 1: Rating (1–5)</h4>
                <p class="text-muted">Scale: 1 = Very Poor | 5 = Excellent</p>

                @foreach (var q in new[]
                                {
                                new { Property="Commitment", Label="1. Commitment and Results", Description="The exhibition clearly demonstrated the government’s commitment to delivering on its promises and transitioning to a digital government." },
                                new { Property="Transparency", Label="2. Transparency and Service Improvement", Description="Digital transformation efforts presented (e.g., e-services) show improvements in transparency, efficiency, and reduction of corruption." },
                                new { Property="Innovation", Label="3. Local Innovation and Digital Sovereignty", Description="The in-house technological solutions showcased reflect strong local innovation and reduce dependence on foreign systems." },
                                new { Property="CommunityImpact", Label="4. Community Impact and Accessibility", Description="Projects such as MESOB and Digitalizing Villages (Ganda) improve access to services, especially for rural communities." },
                                new { Property="YouthOpportunity", Label="5. Youth Inspiration and Opportunities", Description="The exhibition inspired me to see technology and innovation as opportunities for employment, entrepreneurship, and development." }
                                })
                {
                    <div class="question">
                        <strong>@q.Label</strong>
                        <p class="text-muted small">@q.Description</p>
                        <div class="rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <input type="radio" id="@($"{q.Property}_{i}")" name="@q.Property" value="@i" required />
                                <label for="@($"{q.Property}_{i}")">@i</label>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Section 2: Open-ended Questions -->
            <div class="form-section">
                <h4>🔹 Section 2: Open-Ended Questions</h4>
                <div class="question">
                    <label asp-for="Impressed">6. What impressed you most about the exhibition?</label>
                    <textarea asp-for="Impressed" rows="3"></textarea>
                </div>
                <div class="question">
                    <label asp-for="Improvement">7. In your opinion, what areas need improvement?</label>
                    <textarea asp-for="Improvement" rows="3"></textarea>
                </div>
                <div class="question">
                    <label asp-for="DigitalService">8. How can digital technologies better serve communities in Oromia?</label>
                    <textarea asp-for="DigitalService" rows="3"></textarea>
                </div>
                <div class="question">
                    <label asp-for="YouthSupport">9. What suggestions do you have to further support youth in technology and innovation?</label>
                    <textarea asp-for="YouthSupport" rows="3"></textarea>
                </div>
            </div>

            <!-- Section 3: Optional Info -->
            <div class="form-section">
                <h4>🔹 Section 3: General Information (Optional)</h4>
                <label asp-for="AgeGroup">• Age Group:</label>
                <select asp-for="AgeGroup" class="form-select">
                    <option>Under 18</option>
                    <option>18–25</option>
                    <option>26–35</option>
                    <option>36–50</option>
                    <option>50+</option>
                </select>

                <label asp-for="Occupation">• Occupation:</label>
                <input asp-for="Occupation" placeholder="Occupation" />

                <label asp-for="Region">• Region/City:</label>
                <input asp-for="Region" placeholder="Region/City" />
            </div>

            <button type="submit" class="btn btn-primary mt-3">Submit Feedback</button>
        </form>
    </div>

    <!-- Safe JS Serialization (no warnings) -->
    <script>
        const feedbackData = @Html.Raw(jsonData);
        console.log(feedbackData);
    </script>

</body>
</html>