@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>OSTA Feedback QR Page</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 30px;
            background: #f5f7fa;
        }

        .header img {
            max-height: 80px;
            margin-bottom: 10px;
        }

        .header h2 {
            color: #003366;
        }

        .qr-box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin: 20px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }

            .qr-box img {
                max-width: 250px;
            }

        .btn-primary {
            background: #003366;
            border-color: #003366;
        }

        .btn-success {
            background: #28a745;
            border-color: #28a745;
        }

        /* IMPORTANT FIX */
        @@media print {
            button {
                display: none;
            }
        }
    </style>
</head>
<body>

    <!-- Header -->
    <div class="header">
        <img src="~/images/osta-logo.webp" asp-append-version="true" alt="OSTA Logo" />
        <h2>OSTA Exhibition Feedback</h2>
        <p><strong>Scan QR Code to Submit Feedback</strong></p>
        <p>
            Theme: Commitment through Action: Digital Transformation and Technological Innovation in Oromia
        </p>
        <p><strong>Location:</strong> Oromo Cultural Center, Addis Ababa</p>
    </div>

    <!-- QR Codes -->
    <div class="container">
        <div class="row justify-content-center">

            <!-- VIP -->
            <div class="col-md-5 qr-box">
                <h4>VIP Visitors</h4>
                <img src="@Url.Action("GenerateQR", "Feedback", new { visitorType = "VIP" })" />

                <div class="mt-3">
                    <a href="@Url.Action("Create", "Feedback", new { visitorType = "VIP" })"
                       class="btn btn-primary mb-2">
                        Open VIP Form
                    </a>
                    <br />
                    <button class="btn btn-success" onclick="printSingle('VIP')">
                        Print VIP QR
                    </button>
                </div>
            </div>

            <!-- General -->
            <div class="col-md-5 qr-box">
                <h4>General Visitors</h4>
                <img src="@Url.Action("GenerateQR", "Feedback", new { visitorType = "General" })" />

                <div class="mt-3">
                    <a href="@Url.Action("Create", "Feedback", new { visitorType = "General" })"
                       class="btn btn-primary mb-2">
                        Open General Form
                    </a>
                    <br />
                    <button class="btn btn-success" onclick="printSingle('General')">
                        Print General QR
                    </button>
                </div>
            </div>

        </div>
    </div>

    <!-- Print Full Page -->
    <div class="mt-4">
        <button class="btn btn-dark" onclick="window.print()">
            🖨 Print Full Page
        </button>
    </div>

    <!-- Script -->
    <script>
        function printSingle(type) {
            const url = type === "VIP"
                ? '@Url.Action("GenerateQR", "Feedback", new { visitorType = "VIP" })'
                : '@Url.Action("GenerateQR", "Feedback", new { visitorType = "General" })';

            const popup = window.open('', '_blank', 'width=400,height=500');

            popup.document.write(`
                <html>
                <head>
                    <title>${type} QR Code</title>
                    <style>
                        body { text-align:center; font-family:Arial; padding:40px; }
                        img { max-width:300px; margin-top:20px; }
                        h2 { color:#003366; }
                    </style>
                </head>
                <body>
                    <img src="/images/osta-logo.png" style="max-height:80px;" />
                    <h2>${type} Visitors</h2>
                    <p>Scan to Submit Feedback</p>
                    <img src="${url}" />
                    <script>
                        window.onload = function() { window.print(); }
                    <\/script>
                </body>
                </html>
            `);

            popup.document.close();
        }
    </script>

</body>
</html>